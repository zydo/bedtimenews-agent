# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Chat provider: openai, deepseek, gemini, claude, etc.
LLM_PROVIDER=deepseek
# Embedding provider (decoupled from chat). Defaults to LLM_PROVIDER if unset.
EMBEDDING_PROVIDER=siliconflow

# DeepSeek Configuration (chat via OpenAI-compatible endpoint)
# DEEPSEEK_API_KEY is read from the shell environment, not stored here.
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_GENERATION_MODEL=deepseek-v4-flash

# SiliconFlow Configuration (embeddings via OpenAI-compatible endpoint)
# SILICONFLOW_API_KEY is read from the shell environment, not stored here.
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
#
# ⚠️  CHANGING THE EMBEDDING PROVIDER/MODEL IS NOT A SIMPLE .env EDIT.
# Each embedding model emits a fixed vector dimension (see EMBEDDING_DIM below),
# which sizes the `embedding halfvec(N)` column in the DB schema. The model's
# output size and the column must match, or inserts fail with
# "expected N dimensions, not M".
# Also note: switching models requires RE-EMBEDDING the whole corpus even when
# the dimension is unchanged — vectors from different models are not comparable.
# EMBEDDING_DIM only sizes the column on FIRST database init; changing it later
# does NOT alter an existing table. See the "Changing the embedding model"
# runbook in indexer/README.md before changing anything here.

# Embedding vector dimension — MUST equal the embedding model's output size.
# Consumed by storage/postgres/init.sh when the DB volume is first created.
# Common values: Qwen/Qwen3-Embedding-4B=2560, text-embedding-3-small=1536,
# text-embedding-3-large=3072, text-embedding-004=768.
# Only the dimension is configurable. The column type is fixed to pgvector
# `halfvec`, a universal default that fits any model up to 4000 dims (incl. the
# OpenAI models) at half the storage with negligible recall loss — so switching
# models only requires matching EMBEDDING_DIM, not the type.
EMBEDDING_DIM=2560

# OpenAI Configuration (unused — kept for reference)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_FAST_MODEL=gpt-5.4-mini
# OPENAI_GENERATION_MODEL=gpt-5.4
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini Configuration (for future use)
# GEMINI_API_KEY=...
# GEMINI_FAST_MODEL=gemini-2.0-flash-exp
# GEMINI_GENERATION_MODEL=gemini-2.5-pro
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# Claude Configuration (for future use)
# ANTHROPIC_API_KEY=...
# CLAUDE_FAST_MODEL=claude-3-5-haiku
# CLAUDE_GENERATION_MODEL=claude-3-5-sonnet
# CLAUDE_EMBEDDING_MODEL=# Use OpenAI or Voyage for embeddings

# ============================================================================
# Service Configuration
# ============================================================================
# Agent Backend Configuration
AGENT_BACKEND_HOST=agent # Agent Docker service name in docker-compose.yml (not container name)
AGENT_BACKEND_PORT=8000

# Frontend Configuration
# The web frontend is reached via Caddy (public profile) or directly on the host
# (local profile). FRONTEND_PORT sets the published host port for --profile local.
FRONTEND_PORT=8000

# Caddy / TLS Configuration (required for public deployment only)
# For local testing (--profile local), these can be left as-is or unused.
# For public deployment (--profile public):
#   - DOMAIN must be a domain you control with an A/AAAA record pointing at this server
#   - ACME_EMAIL is recommended for Let's Encrypt expiry notices (optional but recommended)
#   - Firewall must allow inbound ports 80 and 443 from anywhere (0.0.0.0/0)
#   - This setup works for Cloudflare grey-cloud (DNS-only). See README for orange-cloud setup.
DOMAIN=chat.bedtime.blog
ACME_EMAIL=admin@example.com

# PostgreSQL Configuration
POSTGRES_HOST=postgres # Postgres Docker service name in docker-compose.yml (not container name)
POSTGRES_DB=postgres_db
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_PORT=5432

# ============================================================================
# Model Configuration
# ============================================================================
# Embedding Batch Size (applies to all providers)
EMBEDDING_BATCH_SIZE=20

# Vector Search Configuration
# Similarity threshold for document retrieval (0.0-1.0, higher = stricter matching)
MATCH_THRESHOLD=0.4

# ============================================================================
# Indexer Configuration
# ============================================================================
# Cron schedule: "minute hour day month weekday"
# Examples:
#   Every hour: 0 * * * *
#   Every 30 min: */30 * * * *
#   Every 6 hours: 0 */6 * * *
#   Daily at 2 AM: 0 2 * * *
INDEXER_CRON_SCHEDULE=0 * * * *
